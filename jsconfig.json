{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["pages/*"],
      "@pages": ["pages/index.js"],
      "@utils/*": ["utils/*"],
      "@utils": ["utils/index.js"],
      "@fixtures/*": ["tests/fixtures/*"]
    }
  },
  "include": [
    "tests/**/*.js",
    "pages/**/*.js",
    "utils/**/*.js",
    "playwright.config.js"
  ],
  "exclude": ["node_modules"]
}
